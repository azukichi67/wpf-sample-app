<Window x:Class="SampleApp.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SampleApp.UI"
        xmlns:vm="clr-namespace:SampleApp.UI.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="MainWindow" Height="450" Width="800">
    <DockPanel>
        <StackPanel DockPanel.Dock="Left">
            <TextBlock Text="Menu" FontSize="20" Margin="10"/>
            <Button Content="カウンター (MVVM)" Command="{Binding MoveCounterMvvmCommand}" Margin="5" Width="140"/>
            <Button Content="カウンター (Code-Behind)" Command="{Binding MoveCounterCodeBehindCommand}" Margin="5" Width="140"/>
            <Button Content="CSV変換" Command="{Binding MoveExcelToCsvCommand}" Margin="5" Width="140"/>
        </StackPanel>
        <Frame x:Name="MainFrame" Content="{Binding CurrentPage}" NavigationUIVisibility="Hidden"/>
    </DockPanel>
</Window>
