<Page x:Class="SampleApp.UI.Views.ExcelToCsvPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:controls="clr-namespace:SampleApp.UI.Controls"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ExcelToCsvPage">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="500">
            <TextBlock Text="ExcelからCSVへ変換" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <!-- 入力ファイル -->
            <TextBlock Text="Excelファイル" Margin="0,0,0,4"/>
            <controls:FilePickerControl
                FilePath="{Binding ExcelFilePath, Mode=TwoWay}"
                Filter="Excelファイル|*.xlsx;*.xls"
                Margin="0,0,0,12"/>

            <!-- 出力ファイル -->
            <TextBlock Text="出力CSVファイル" Margin="0,0,0,4"/>
            <controls:FilePickerControl
                FilePath="{Binding CsvFilePath, Mode=TwoWay}"
                Filter="CSVファイル|*.csv"
                IsSave="True"
                Margin="0,0,0,20"/>

            <!-- 変換ボタン -->
            <Button Content="変換"
                    Command="{Binding ConvertCommand}"
                    Width="100" HorizontalAlignment="Center"
                    Margin="0,0,0,12"/>

            <!-- ステータス -->
            <TextBlock Text="{Binding StatusMessage}"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>
