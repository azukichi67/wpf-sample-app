<Page x:Class="SampleApp.UI.Views.CounterBehidePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SampleApp.UI.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CounterBehidePage">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="カウンター (Code-Behind)" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="DecrementButton" Content="-" Click="DecrementButton_Click" Margin="10" Width="50"/>
                <TextBlock x:Name="CountText" FontSize="20" Margin="10" VerticalAlignment="Center"/>
                <Button Content="+" Click="IncrementButton_Click" Margin="10" Width="50"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
