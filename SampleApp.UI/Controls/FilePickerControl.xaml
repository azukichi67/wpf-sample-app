<UserControl x:Class="SampleApp.UI.Controls.FilePickerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">

    <DockPanel>
        <Button Content="参照..."
                DockPanel.Dock="Right"
                Width="80" Margin="8,0,0,0"
                Click="OnBrowseClicked"/>
        <TextBox Text="{Binding FilePath, ElementName=Root, UpdateSourceTrigger=PropertyChanged}"
                 IsReadOnly="True"/>
    </DockPanel>
</UserControl>
